# POP CLI Configuration

# Required: Private key for signing transactions
POP_PRIVATE_KEY=0x...

# Default chain ID (42161=Arbitrum, 100=Gnosis, 11155111=Sepolia, 84532=Base Sepolia)
POP_DEFAULT_CHAIN=100

# Default organization (name or hex ID). Used when --org is not provided.
POP_DEFAULT_ORG=

# RPC URL for the default chain (optional if using built-in defaults)
POP_RPC_URL=

# Subgraph URL for the default chain (optional if using built-in defaults)
POP_SUBGRAPH_URL=

# IPFS endpoints (optional — defaults to The Graph's IPFS)
POP_IPFS_API_URL=https://api.thegraph.com/ipfs/api/v0
POP_IPFS_GATEWAY_URL=https://ipfs.io/ipfs/

# Per-chain RPC overrides (used when --chain differs from default)
POP_ARBITRUM_RPC=
POP_ARBITRUM_SUBGRAPH=
POP_GNOSIS_RPC=
POP_GNOSIS_SUBGRAPH=
POP_SEPOLIA_RPC=
POP_SEPOLIA_SUBGRAPH=
POP_BASE_SEPOLIA_RPC=
POP_BASE_SEPOLIA_SUBGRAPH=
