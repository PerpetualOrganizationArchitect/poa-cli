{
  "name": "@poa/cli",
  "version": "0.1.0",
  "description": "CLI for the POP (Proof of Participation) protocol",
  "bin": {
    "pop": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:brain-merge": "yarn build && node test/scripts/brain-merge-e2e.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@chainsafe/libp2p-gossipsub": "^14",
    "@chainsafe/libp2p-noise": "^16",
    "@chainsafe/libp2p-yamux": "^7",
    "@libp2p/autonat": "^2.0.38",
    "@libp2p/bootstrap": "^11.0.47",
    "@libp2p/circuit-relay-v2": "^3.2.24",
    "@libp2p/identify": "^3",
    "@libp2p/mdns": "^11",
    "@libp2p/tcp": "^10",
    "@x402/evm": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "blockstore-fs": "^2",
    "bs58": "^6.0.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "datastore-fs": "^9",
    "dotenv": "^16.4.7",
    "ethers": "5.7.2",
    "graphql": "^16.9.0",
    "graphql-request": "^6.1.0",
    "helia": "^5.5.1",
    "libp2p": "^2.10.0",
    "ora": "^5.4.1",
    "permissionless": "^0.3.5",
    "viem": "^2.47.12",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "resolutions": {
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
